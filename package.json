{
  "name": "@trebired/logger",
  "version": "2.4.0",
  "description": "Local-first JSONL logger with durable writes, partitions, export archives, native storage acceleration, redaction, query helpers, and browser runtimes.",
  "license": "AGPL-3.0-only",
  "keywords": [
    "logger",
    "logging",
    "structured-logging",
    "jsonl",
    "backend",
    "browser",
    "frontend",
    "node",
    "bun"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Trebired/logger"
  },
  "bugs": {
    "url": "https://github.com/Trebired/logger/issues"
  },
  "homepage": "https://github.com/Trebired/logger#readme",
  "type": "module",
  "engines": {
    "node": ">=18",
    "bun": ">=1.0.0"
  },
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "bun@1.3.12",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser/index.d.ts",
      "import": "./dist/browser/index.js"
    },
    "./browser/react": {
      "types": "./dist/browser/react.d.ts",
      "import": "./dist/browser/react.js"
    }
  },
  "files": [
    "dist",
    "native/*.node",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "build:native": "node ./scripts/build-native.mjs",
    "build:native:matrix": "node ./scripts/build-native-matrix.mjs",
    "demo": "bun run examples/dummy.ts",
    "prepublishOnly": "bun run typecheck && bun test && bun run build && node ./scripts/verify-publish.mjs",
    "publish:npm": "bun run build:native:matrix && npm publish",
    "publish:npm:host": "bun run build:native && TB_LOGGER_ALLOW_HOST_ONLY_PUBLISH=1 npm publish",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "verify:pack": "node ./scripts/verify-pack.mjs"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/bun": "^1.3.4",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.2",
    "@types/react-test-renderer": "^19.1.0",
    "@types/tar-stream": "^3.1.4",
    "react": "^19.2.0",
    "react-test-renderer": "^19.2.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "fflate": "^0.8.3",
    "tar-stream": "^3.2.0"
  }
}
