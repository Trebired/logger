{
  "name": "@trebired/logger",
  "version": "2.0.0",
  "description": "Structured server and browser logger with JSONL storage, shared event semantics, custom weighted levels, redaction, retention, and local query helpers.",
  "license": "MIT",
  "keywords": [
    "logger",
    "logging",
    "structured-logging",
    "jsonl",
    "backend",
    "browser",
    "frontend",
    "node",
    "bun"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trebired/logger.git"
  },
  "bugs": {
    "url": "https://github.com/trebired/logger/issues"
  },
  "homepage": "https://github.com/trebired/logger#readme",
  "type": "module",
  "engines": {
    "node": ">=18",
    "bun": ">=1.0.0"
  },
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "bun@1.3.12",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser/index.d.ts",
      "import": "./dist/browser/index.js"
    },
    "./browser/react": {
      "types": "./dist/browser/react.d.ts",
      "import": "./dist/browser/react.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "demo": "bun run examples/dummy.ts",
    "prepublishOnly": "bun run typecheck && bun test && bun run build",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/bun": "^1.3.4",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.2",
    "@types/react-test-renderer": "^19.1.0",
    "react": "^19.2.0",
    "react-test-renderer": "^19.2.0",
    "typescript": "^6.0.2"
  }
}
